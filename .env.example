# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored — never commit real secrets. Keys mirror src/config/schema.ts.

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=3000                       # web server port (min 3000)
WORKER_PORT=3001                # worker health-server port (defaults to 3001)
NODE_ENV=development            # development | production | test
API_BASE_URL=http://localhost:3000
PROXY_HOP_COUNT=0               # 0 = no proxy (dev), 1 = ALB, 2 = CF+ALB
LOG_LEVEL=debug                 # pino level (trace|debug|info|warn|error)

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=change-me

# ─────────────────────────────────────────────
# Redis (cache / rate-limit — eviction policy OK)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                 # optional (blank = no auth)

# ─────────────────────────────────────────────
# BullMQ Redis (SEPARATE instance — must be noeviction in prod)
# Cache eviction would silently drop queued jobs. Leave blank in dev to fall
# back to the cache Redis above (harmless eviction-policy warning at low volume).
# In prod point these at a dedicated noeviction Redis.
# ─────────────────────────────────────────────
REDIS_BULL_HOST=
REDIS_BULL_PORT=
REDIS_BULL_PASSWORD=

# ─────────────────────────────────────────────
# MongoDB
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:pass@cluster.xxxx.mongodb.net/?retryWrites=true&w=majority
#   (if your DNS blocks SRV, use the non-SRV mongodb:// string with shard hosts)
# ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=your_db

# ─────────────────────────────────────────────
# AUTH / JWT
# ─────────────────────────────────────────────
API_SECRET_KEY=change-me-min-16-chars

# CAPTCHA (Cloudflare Turnstile) — feature-flagged. OFF = inert (no captcha).
# Turn ON only after the frontend renders the Turnstile widget and sends the
# token, else logins from risky IPs will be blocked (no token to verify).
# Test keys below always pass (Cloudflare dummy keys for dev):
#   FE site key (always-pass): 1x00000000000000000000AA
CAPTCHA_ENABLED=false
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
JWT_USER_SECRET=generate-a-random-secret-min-32-chars
JWT_ADMIN_SECRET=generate-a-different-secret-min-32-chars
JWT_ISSUER=https://api.example.com

# ─────────────────────────────────────────────
# Swagger UI basic-auth (also gates /health?detailed=true in prod)
# ─────────────────────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me-min-8

# ─────────────────────────────────────────────
# AWS S3
# ─────────────────────────────────────────────
S3_BUCKET_UPLOADS=your-uploads-bucket
S3_BUCKET_REPORTS=your-reports-bucket

# ─────────────────────────────────────────────
# AWS SQS (full queue URLs)
# ─────────────────────────────────────────────
SQS_QUEUE_URL_NOTIFICATIONS=https://sqs.<region>.amazonaws.com/<account-id>/notifications
SQS_QUEUE_URL_REPORTS=https://sqs.<region>.amazonaws.com/<account-id>/reports
SQS_QUEUE_URL_EMAILS=https://sqs.<region>.amazonaws.com/<account-id>/emails

# ─────────────────────────────────────────────
# AWS CloudFront
# ─────────────────────────────────────────────
CLOUDFRONT_KEY_PAIR_ID=your-key-pair-id
CLOUDFRONT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
CLOUDFRONT_DOMAIN_CDN=your-cdn.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID_CDN=your-cdn-distribution-id
CLOUDFRONT_DOMAIN_REPORTS=your-reports.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID_REPORTS=your-reports-distribution-id

# ─────────────────────────────────────────────
# CORS (comma-separated origins)
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
